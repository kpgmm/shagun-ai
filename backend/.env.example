# MongoDB
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=shagun_db

# Auth
JWT_SECRET=<64-char random hex string>   # generate: openssl rand -hex 32
JWT_EXPIRE_MINUTES=10080                  # 7 days

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=<razorpay_key_secret>
RAZORPAY_WEBHOOK_SECRET=<razorpay_webhook_secret>

# Twilio WhatsApp (https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=<twilio_auth_token>
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox number (or your approved number)

# Frontend (update for production)
FRONTEND_URL=http://localhost:3000
